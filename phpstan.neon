includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - app/

    # Level 9 for stricter type checking
    level: 9

    # Ignore generated IDE helper files
    excludePaths:
        - _ide_helper.php
        - .phpstorm.meta.php

    # Report unused private elements
    reportUnmatchedIgnoredErrors: false
    
    # Check missing typehints
    checkMissingIterableValueType: true
